# JWT Configuration
# IMPORTANT: Use a strong secret (minimum 32 characters)!
# Generate with: openssl rand -base64 32
jwt.secret=CHANGE_THIS_TO_A_STRONG_SECRET_MINIMUM_32_CHARACTERS_LONG
jwt.expiration.ms=86400000

# Database Configuration (optional, can also use db.properties)
# db.url=jdbc:postgresql://localhost:5432/otp_service
# db.username=postgres
# db.password=postgres

# Email Configuration
# email.username=your_email@gmail.com
# email.password=your_app_password
# email.from=your_email@gmail.com

# SMS SMPP Configuration
# smpp.host=localhost
# smpp.port=2775
# smpp.system_id=smppclient1
# smpp.password=password

# Telegram Configuration
# telegram.bot.token=YOUR_BOT_TOKEN
# telegram.chat.id=YOUR_CHAT_ID